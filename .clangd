CompileFlags:
  Compiler: g++
  Add:
    - "-I/home/tommy/projects/Agris-Sim/include"
    - "-I/home/tommy/projects/Agris-Sim/teensy_include"
    - "-std=gnu++17"
    - "-DSFML_STATIC"
    - "-DYAML_CPP_STATIC_DEFINE"
    - "-I/usr/include/c++/13"
    - "-I/usr/include/x86_64-linux-gnu/c++/13"
    - "-I/usr/include/c++/13/backward"
    - "-I/usr/lib/gcc/x86_64-linux-gnu/13/include"
    - "-I/usr/local/include"
    - "-I/usr/include/x86_64-linux-gnu"
    - "-I/usr/include"
  Remove:
    - "-m*"
    - "--target=*"